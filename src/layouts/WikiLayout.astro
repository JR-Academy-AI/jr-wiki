---
import BaseLayout from './BaseLayout.astro';
import WikiSidebar from '@/components/WikiSidebar.astro';
import PrevNextNav from '@/components/PrevNextNav.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';

interface Chapter { slug: string; title: string; order: number; href: string; }
interface NavItem { title: string; href: string; }
interface Props {
	title: string;
	description?: string;
	bookTitle: string;
	bookSlug: string;
	chapters: Chapter[];
	currentSlug: string;
	prev?: NavItem;
	next?: NavItem;
}

const { title, description, bookTitle, bookSlug, chapters, currentSlug, prev, next } = Astro.props;
const breadcrumbs = [
	{ label: '电子书', href: '/learn-wiki/' },
	{ label: bookTitle, href: `/learn-wiki/${bookSlug}/` },
	{ label: title },
];
---

<BaseLayout title={`${title} — ${bookTitle}`} description={description}>
	<div class="wiki-page container">
		<div class="wiki-layout">
			<WikiSidebar bookTitle={bookTitle} chapters={chapters} currentSlug={currentSlug} />
			<article class="wiki-content">
				<Breadcrumb items={breadcrumbs} />
				<button class="sidebar-toggle" id="sidebarToggle" aria-label="打开目录">
					<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
						<line x1="3" y1="6" x2="21" y2="6" /><line x1="3" y1="12" x2="15" y2="12" /><line x1="3" y1="18" x2="18" y2="18" />
					</svg>
					<span>目录</span>
				</button>
				<h1 class="chapter-title">{title}</h1>
				<div class="prose"><slot /></div>
				<PrevNextNav prev={prev} next={next} />
			</article>
		</div>
	</div>
</BaseLayout>

<style>
	.wiki-page { padding-top: 32px; padding-bottom: 60px; }
	.wiki-layout { display: flex; gap: 40px; align-items: flex-start; }
	.wiki-content { flex: 1; min-width: 0; max-width: var(--content-width); }
	.chapter-title { font-size: clamp(24px, 3.5vw, 34px); margin-bottom: 32px; padding-bottom: 16px; border-bottom: var(--border-sm); }
	.sidebar-toggle { display: none; align-items: center; gap: 6px; background: var(--color-white); border: var(--border-sm); box-shadow: var(--shadow-sm); padding: 8px 14px; font-family: var(--font-heading); font-weight: 700; font-size: 13px; cursor: pointer; margin-bottom: 20px; transition: transform 0.15s, box-shadow 0.15s; }
	.sidebar-toggle:hover { transform: translate(3px,3px); box-shadow: none; }
	@media (max-width: 1024px) { .wiki-layout { flex-direction: column; } .sidebar-toggle { display: flex; } }
</style>

<script>
	const toggle = document.getElementById('sidebarToggle');
	const sidebar = document.getElementById('wikiSidebar');
	toggle?.addEventListener('click', () => sidebar?.classList.toggle('open'));
	document.addEventListener('click', (e) => {
		const target = e.target as HTMLElement;
		if (sidebar?.classList.contains('open') && !sidebar.contains(target) && target !== toggle && !toggle?.contains(target)) {
			sidebar.classList.remove('open');
		}
	});
</script>
