---
import BaseLayout from './BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';

interface Props {
	title: string;
	description?: string;
	tags?: string[];
	date?: Date;
	author?: string;
}

const { title, description, tags = [], date, author = 'JR Academy' } = Astro.props;
const formattedDate = date ? new Intl.DateTimeFormat('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' }).format(date) : null;
const breadcrumbs = [
	{ label: '首页', href: '/learn-wiki/' },
	{ label: '文章', href: '/learn-wiki/articles/' },
	{ label: title },
];
---

<BaseLayout title={title} description={description} type="article">
	<article class="article-page container">
		<Breadcrumb items={breadcrumbs} />
		<header class="article-header">
			<h1 class="article-title">{title}</h1>
			{description && <p class="article-subtitle">{description}</p>}
			<div class="article-meta">
				{formattedDate && <time class="meta-date">{formattedDate}</time>}
				{author && <span class="meta-author">{author}</span>}
			</div>
			{tags.length > 0 && (
				<div class="article-tags">
					{tags.map((tag) => <a href={`/learn-wiki/articles/tags/${tag}/`} class="tag">{tag}</a>)}
				</div>
			)}
		</header>
		<div class="article-content prose"><slot /></div>
	</article>
</BaseLayout>

<style>
	.article-page { max-width: var(--content-width); padding-top: 40px; padding-bottom: 60px; }
	.article-header { margin-bottom: 40px; padding-bottom: 32px; border-bottom: var(--border-sm); }
	.article-title { font-size: clamp(26px, 4vw, 38px); margin-bottom: 12px; }
	.article-subtitle { font-size: 17px; color: var(--color-grey); line-height: 1.6; margin-bottom: 16px; }
	.article-meta { display: flex; align-items: center; gap: 16px; margin-bottom: 12px; }
	.meta-date, .meta-author { font-family: var(--font-mono); font-size: 13px; color: var(--color-grey); }
	.article-tags { display: flex; gap: 8px; flex-wrap: wrap; }
	.article-tags .tag { text-decoration: none; transition: transform 0.1s; }
	.article-tags .tag:hover { transform: translate(2px, 2px); }
</style>
