---
interface Props {
	title: string;
	description: string;
	href: string;
	tags?: string[];
	date?: Date;
}
const { title, description, href, tags = [], date } = Astro.props;
const formattedDate = date ? new Intl.DateTimeFormat('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' }).format(date) : null;
---

<a href={href} class="article-card card">
	<h3 class="card-title">{title}</h3>
	<p class="card-desc">{description}</p>
	<div class="card-meta">
		{formattedDate && <time class="card-date">{formattedDate}</time>}
		{tags.length > 0 && <div class="card-tags">{tags.slice(0, 3).map((tag) => <span class="tag">{tag}</span>)}</div>}
	</div>
</a>

<style>
	.article-card { display: block; text-decoration: none; color: inherit; }
	.card-title { font-size: 18px; margin-bottom: 8px; line-height: 1.3; }
	.card-desc { font-size: 14px; color: var(--color-grey); line-height: 1.6; margin-bottom: 12px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
	.card-meta { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
	.card-date { font-family: var(--font-mono); font-size: 12px; color: var(--color-grey); }
	.card-tags { display: flex; gap: 6px; flex-wrap: wrap; }
</style>
