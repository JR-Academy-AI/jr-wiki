---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import ArticleCard from '@/components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles');
const articles = allArticles.sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());
const allTags = [...new Set(articles.flatMap((a) => a.data.tags))].sort();
const breadcrumbs = [{ label: '首页', href: '/learn-wiki/' }, { label: '文章' }];
---

<BaseLayout title="文章" description="JR Academy 技术文章">
	<div class="page container">
		<Breadcrumb items={breadcrumbs} />
		<h1 class="page-title">文章</h1>
		<p class="page-desc">独立的技术文章和学习笔记</p>
		{allTags.length > 0 && (
			<div class="tag-filter">
				{allTags.map((tag) => <a href={`/learn-wiki/articles/tags/${tag}/`} class="tag-btn">{tag}</a>)}
			</div>
		)}
		<div class="article-grid">
			{articles.map((a) => <ArticleCard title={a.data.title} description={a.data.description} href={`/learn-wiki/articles/${a.id}/`} tags={a.data.tags} date={a.data.publishDate} />)}
		</div>
	</div>
</BaseLayout>

<style>
	.page { padding: 40px 0 60px; }
	.page-title { margin-bottom: 8px; }
	.page-desc { color: var(--color-grey); font-size: 16px; margin-bottom: 28px; }
	.tag-filter { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 28px; padding-bottom: 20px; border-bottom: var(--border-sm); }
	.tag-btn { font-family: var(--font-mono); font-size: 13px; font-weight: 700; padding: 6px 14px; border: var(--border-sm); background: var(--color-white); color: var(--color-dark); text-decoration: none; box-shadow: 2px 2px 0 var(--color-black); transition: transform 0.1s, box-shadow 0.1s; }
	.tag-btn:hover { background: var(--color-yellow); transform: translate(2px,2px); box-shadow: none; color: var(--color-dark); }
	.article-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 20px; }
	@media (max-width: 768px) { .article-grid { grid-template-columns: 1fr; } }
</style>
