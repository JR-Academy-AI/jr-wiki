---
import WikiLayout from '@/layouts/WikiLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
	const allBooks = await getCollection('books');
	const allWikiPages = await getCollection('wiki');
	const toSlug = (id: string) => id.split('/').pop()!;
	const paths: any[] = [];

	for (const book of allBooks) {
		const bookSlug = book.id.split('/')[0];
		const chapters = allWikiPages.filter((p) => p.data.wiki === bookSlug).sort((a, b) => a.data.order - b.data.order);
		for (let i = 0; i < chapters.length; i++) {
			const ch = chapters[i];
			const prev = i > 0 ? chapters[i - 1] : undefined;
			const next = i < chapters.length - 1 ? chapters[i + 1] : undefined;
			paths.push({
				params: { wiki: bookSlug, slug: toSlug(ch.id) },
				props: {
					entry: ch, bookTitle: book.data.title, bookSlug,
					chapters: chapters.map((c) => ({ slug: c.id, title: c.data.title, order: c.data.order, href: `/learn-wiki/${bookSlug}/${toSlug(c.id)}/` })),
					prev: prev ? { title: prev.data.title, href: `/learn-wiki/${bookSlug}/${toSlug(prev.id)}/` } : undefined,
					next: next ? { title: next.data.title, href: `/learn-wiki/${bookSlug}/${toSlug(next.id)}/` } : undefined,
				},
			});
		}
	}
	return paths;
}

const { entry, bookTitle, bookSlug, chapters, prev, next } = Astro.props;
const { Content } = await render(entry);
---

<WikiLayout title={entry.data.title} description={entry.data.description} bookTitle={bookTitle} bookSlug={bookSlug} chapters={chapters} currentSlug={entry.id} prev={prev} next={next}>
	<Content />
</WikiLayout>
