---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
	const allBooks = await getCollection('books');
	const allWikiPages = await getCollection('wiki');
	return allBooks.map((book) => {
		const bookSlug = book.id.split('/')[0];
		const chapters = allWikiPages.filter((p) => p.data.wiki === bookSlug).sort((a, b) => a.data.order - b.data.order);
		return {
			params: { wiki: bookSlug },
			props: {
				book: book.data, bookSlug,
				chapters: chapters.map((ch) => { const parts = ch.id.split('/'); return { slug: parts[parts.length - 1], title: ch.data.title, description: ch.data.description, order: ch.data.order }; }),
			},
		};
	});
}

const { book, bookSlug, chapters } = Astro.props;
const breadcrumbs = [{ label: '电子书', href: '/learn-wiki/' }, { label: book.title }];
---

<BaseLayout title={book.title} description={book.description}>
	<div class="page container">
		<Breadcrumb items={breadcrumbs} />
		<div class="book-header">
			<h1>{book.title}</h1>
			<p class="book-desc">{book.description}</p>
			{book.tags.length > 0 && <div class="book-tags">{book.tags.map((t: string) => <span class="tag">{t}</span>)}</div>}
		</div>
		<div class="toc">
			<h2 class="toc-title">目录 ({chapters.length} 章)</h2>
			<div class="toc-list">
				{chapters.map((ch: any, i: number) => (
					<a href={`/learn-wiki/${bookSlug}/${ch.slug}/`} class="toc-item card-sm">
						<span class="toc-num">{String(i + 1).padStart(2, '0')}</span>
						<div class="toc-content"><h3 class="toc-item-title">{ch.title}</h3>{ch.description && <p class="toc-item-desc">{ch.description}</p>}</div>
						<span class="toc-arrow">→</span>
					</a>
				))}
			</div>
		</div>
		{chapters.length > 0 && <div class="start-reading"><a href={`/learn-wiki/${bookSlug}/${chapters[0].slug}/`} class="btn btn-primary">开始阅读第一章 →</a></div>}
	</div>
</BaseLayout>

<style>
	.page { padding: 40px 0 60px; max-width: var(--content-width); }
	.book-header { margin-bottom: 40px; padding-bottom: 28px; border-bottom: var(--border-sm); }
	.book-header h1 { margin-bottom: 12px; }
	.book-desc { font-size: 16px; color: var(--color-grey); line-height: 1.6; margin-bottom: 16px; }
	.book-tags { display: flex; gap: 8px; flex-wrap: wrap; }
	.toc-title { font-size: 20px; margin-bottom: 20px; }
	.toc-list { display: flex; flex-direction: column; gap: 10px; }
	.toc-item { display: flex; align-items: center; gap: 16px; text-decoration: none; color: inherit; }
	.toc-num { font-family: var(--font-mono); font-size: 14px; font-weight: 700; color: var(--color-grey); flex-shrink: 0; }
	.toc-content { flex: 1; }
	.toc-item-title { font-size: 16px; font-weight: 700; }
	.toc-item-desc { font-size: 13px; color: var(--color-grey); margin-top: 4px; }
	.toc-arrow { font-size: 18px; color: var(--color-grey); flex-shrink: 0; transition: transform 0.15s; }
	.toc-item:hover .toc-arrow { transform: translateX(4px); color: var(--color-red); }
	.start-reading { margin-top: 36px; text-align: center; }
</style>
