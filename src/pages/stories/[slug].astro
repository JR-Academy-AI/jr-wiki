---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
	const stories = await getCollection('stories');
	return stories.map((s) => ({ params: { slug: s.id }, props: { story: s } }));
}

const { story } = Astro.props;
const { Content } = await render(story);
const formattedDate = new Intl.DateTimeFormat('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' }).format(story.data.publishDate);
const breadcrumbs = [{ label: '首页', href: '/learn-wiki/' }, { label: '学员故事', href: '/learn-wiki/stories/' }, { label: story.data.name }];
---

<BaseLayout title={story.data.title} description={story.data.description} type="article">
	<article class="story-page container">
		<Breadcrumb items={breadcrumbs} />
		<header class="story-header">
			<div class="story-tags">
				<span class="tag">{story.data.role}</span>
				{story.data.company && <span class="tag" style="background:var(--color-green)">{story.data.company}</span>}
				{story.data.course && <span class="tag" style="background:var(--color-blue);color:#fff">{story.data.course}</span>}
			</div>
			<h1>{story.data.title}</h1>
			{story.data.highlight && <p><span class="highlight">{story.data.highlight}</span></p>}
			<p class="story-desc">{story.data.description}</p>
			<div class="story-meta"><span>{story.data.name}</span><time>{formattedDate}</time></div>
		</header>
		<div class="prose"><Content /></div>
		<div class="story-footer"><a href="/learn-wiki/stories/" class="btn btn-dark">← 查看更多学员故事</a></div>
	</article>
</BaseLayout>

<style>
	.story-page { max-width: var(--content-width); padding-top: 40px; padding-bottom: 60px; }
	.story-header { margin-bottom: 40px; padding-bottom: 28px; border-bottom: var(--border-sm); }
	.story-tags { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 16px; }
	.story-header h1 { margin-bottom: 12px; }
	.story-desc { font-size: 17px; color: var(--color-grey); line-height: 1.6; margin-bottom: 16px; }
	.story-meta { display: flex; gap: 20px; font-family: var(--font-mono); font-size: 13px; color: var(--color-grey); }
	.story-footer { margin-top: 48px; padding-top: 24px; border-top: var(--border-sm); }
</style>
