---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import { getCollection } from 'astro:content';

const stories = (await getCollection('stories')).sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());
const breadcrumbs = [{ label: '首页', href: '/learn-wiki/' }, { label: '学员故事' }];
---

<BaseLayout title="学员故事" description="JR Academy 学员转行成功案例">
	<div class="page container">
		<Breadcrumb items={breadcrumbs} />
		<h1 class="page-title">学员故事</h1>
		<p class="page-desc">真实的转行经历，真实的学习过程</p>
		<div class="story-grid">
			{stories.map((s) => (
				<a href={`/learn-wiki/stories/${s.id}/`} class="story-card card">
					<div class="story-role">
						<span class="tag">{s.data.role}</span>
						{s.data.company && <span class="tag" style="background:var(--color-green)">{s.data.company}</span>}
					</div>
					<h2 class="story-title">{s.data.title}</h2>
					<p class="story-desc">{s.data.description}</p>
					{s.data.highlight && <div><span class="highlight">{s.data.highlight}</span></div>}
					<div class="story-meta"><span>{s.data.name}</span>{s.data.course && <span>{s.data.course}</span>}</div>
				</a>
			))}
		</div>
	</div>
</BaseLayout>

<style>
	.page { padding: 40px 0 60px; }
	.page-title { margin-bottom: 8px; }
	.page-desc { color: var(--color-grey); font-size: 16px; margin-bottom: 32px; }
	.story-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(360px, 1fr)); gap: 20px; }
	.story-card { text-decoration: none; color: inherit; display: flex; flex-direction: column; gap: 12px; }
	.story-role { display: flex; gap: 8px; flex-wrap: wrap; }
	.story-title { font-size: 18px; line-height: 1.3; }
	.story-desc { font-size: 14px; color: var(--color-grey); line-height: 1.6; flex: 1; }
	.story-meta { display: flex; gap: 16px; font-family: var(--font-mono); font-size: 12px; color: var(--color-grey); }
	@media (max-width: 768px) { .story-grid { grid-template-columns: 1fr; } }
</style>
