---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ArticleCard from '@/components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const allBooks = await getCollection('books');
const allWikiPages = await getCollection('wiki');
const allArticles = await getCollection('articles');
const allStories = await getCollection('stories');

const bookList = allBooks
	.map((book) => {
		const bookSlug = book.id.split('/')[0];
		const chapters = allWikiPages.filter((p) => p.data.wiki === bookSlug);
		return { slug: bookSlug, title: book.data.title, description: book.data.description, tags: book.data.tags, order: book.data.order, chapterCount: chapters.length };
	})
	.sort((a, b) => a.order - b.order);

const recentArticles = allArticles.sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()).slice(0, 6);
const recentStories = allStories.sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()).slice(0, 4);
---

<BaseLayout title="JR Learn Wiki" description="JR Academy 知识库 — 电子书、技术文章、帮助中心、学员故事">
	<section class="hero">
		<div class="container hero-inner">
			<div class="tag">LEARN WIKI</div>
			<h1 class="hero-title">JR Academy <span class="highlight">知识库</span></h1>
			<p class="hero-desc">电子书 / 技术文章 / 帮助中心 / 学员故事 — AI 生成与更新，纯静态秒级加载</p>
			<div class="hero-actions">
				<a href="#books" class="btn btn-primary">电子书</a>
				<a href="/learn-wiki/articles/" class="btn btn-dark">文章</a>
				<a href="/learn-wiki/help/" class="btn btn-dark">帮助中心</a>
				<a href="/learn-wiki/stories/" class="btn btn-dark">学员故事</a>
			</div>
		</div>
	</section>

	<section class="section container" id="books">
		<div class="section-header"><h2>电子书</h2></div>
		<div class="book-grid">
			{bookList.map((book) => (
				<a href={`/learn-wiki/${book.slug}/`} class="book-card card">
					<h3 class="book-title">{book.title}</h3>
					<p class="book-desc">{book.description}</p>
					<div class="book-meta">
						<span class="tag">{book.chapterCount} 章</span>
						{book.tags.slice(0, 3).map((t) => <span class="tag" style="background: var(--color-light-grey)">{t}</span>)}
					</div>
				</a>
			))}
		</div>
	</section>

	{recentArticles.length > 0 && (
		<section class="section container">
			<div class="section-header"><h2>最新文章</h2><a href="/learn-wiki/articles/" class="section-link">查看全部 →</a></div>
			<div class="article-grid">
				{recentArticles.map((a) => (
					<ArticleCard title={a.data.title} description={a.data.description} href={`/learn-wiki/articles/${a.id}/`} tags={a.data.tags} date={a.data.publishDate} />
				))}
			</div>
		</section>
	)}

	{recentStories.length > 0 && (
		<section class="section container">
			<div class="section-header"><h2>学员故事</h2><a href="/learn-wiki/stories/" class="section-link">查看全部 →</a></div>
			<div class="story-grid">
				{recentStories.map((s) => (
					<a href={`/learn-wiki/stories/${s.id}/`} class="story-card card">
						<div class="story-tags">
							<span class="tag">{s.data.role}</span>
							{s.data.company && <span class="tag" style="background: var(--color-green)">{s.data.company}</span>}
						</div>
						<h3 class="story-title">{s.data.title}</h3>
						{s.data.highlight && <span class="highlight">{s.data.highlight}</span>}
					</a>
				))}
			</div>
		</section>
	)}
</BaseLayout>

<style>
	.hero { background: var(--color-dark); border-bottom: var(--border); padding: 64px 0; text-align: center; }
	.hero-inner { max-width: 700px; }
	.hero .tag { margin-bottom: 16px; }
	.hero-title { font-size: clamp(30px, 5vw, 48px); color: var(--color-white); margin-bottom: 12px; }
	.hero-desc { color: rgba(255,255,255,0.6); font-size: 16px; line-height: 1.6; margin-bottom: 28px; }
	.hero-actions { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
	.section { padding: 48px 0 0; }
	.section-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px; padding-bottom: 14px; border-bottom: var(--border-sm); }
	.section-header h2 { font-size: 22px; }
	.section-link { font-family: var(--font-mono); font-size: 14px; font-weight: 700; }
	.book-grid, .article-grid, .story-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 20px; }
	.book-card, .story-card { text-decoration: none; color: inherit; display: flex; flex-direction: column; gap: 10px; }
	.book-title, .story-title { font-size: 18px; line-height: 1.3; }
	.book-desc { font-size: 14px; color: var(--color-grey); line-height: 1.6; flex: 1; }
	.book-meta, .story-tags { display: flex; gap: 6px; flex-wrap: wrap; }
	@media (max-width: 768px) { .hero { padding: 40px 0; } .book-grid, .article-grid, .story-grid { grid-template-columns: 1fr; } }
</style>
