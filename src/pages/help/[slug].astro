---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
	const helpItems = await getCollection('help');
	return helpItems.map((item) => ({ params: { slug: item.id }, props: { item } }));
}

const { item } = Astro.props;
const { Content } = await render(item);
const breadcrumbs = [{ label: '首页', href: '/learn-wiki/' }, { label: '帮助中心', href: '/learn-wiki/help/' }, { label: item.data.title }];
---

<BaseLayout title={item.data.title} description={item.data.description}>
	<article class="help-page container">
		<Breadcrumb items={breadcrumbs} />
		<header class="help-header">
			<span class="tag">{item.data.category}</span>
			<h1>{item.data.title}</h1>
			<p class="help-desc">{item.data.description}</p>
		</header>
		<div class="prose"><Content /></div>
		<div class="help-footer"><a href="/learn-wiki/help/" class="btn btn-dark">← 返回帮助中心</a></div>
	</article>
</BaseLayout>

<style>
	.help-page { max-width: var(--content-width); padding-top: 40px; padding-bottom: 60px; }
	.help-header { margin-bottom: 36px; padding-bottom: 24px; border-bottom: var(--border-sm); }
	.help-header .tag { margin-bottom: 12px; }
	.help-header h1 { margin-bottom: 8px; }
	.help-desc { color: var(--color-grey); font-size: 16px; }
	.help-footer { margin-top: 48px; padding-top: 24px; border-top: var(--border-sm); }
</style>
